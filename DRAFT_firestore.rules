rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Accounts (CoA) ---
    function isValidAccount(data) {
      return data.keys().hasAll(['code', 'name', 'category', 'fundType']) &&
             data.keys().size() >= 4 &&
             data.code is string && data.code.size() <= 20 &&
             data.name is string && data.name.size() <= 100 &&
             data.category in ['Asset', 'Liability', 'NetAsset', 'Revenue', 'Expense'] &&
             data.fundType in ['Zakat', 'Infaq', 'Amil', 'General'];
    }

    match /accounts/{accountId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidAccount(incoming());
      allow delete: if isSignedIn(); // In production, we'd limit this if it has balances
    }

    // --- Transactions ---
    function isValidTransaction(data) {
      return data.keys().hasAll(['date', 'description', 'total', 'createdBy']) &&
             data.date is string &&
             data.description is string && data.description.size() <= 500 &&
             data.total is number && data.total >= 0 &&
             data.createdBy == request.auth.uid;
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidTransaction(incoming());
      allow update: if isSignedIn() && isValidTransaction(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['description', 'reference', 'total'])
      );
      allow delete: if isSignedIn() && existing().createdBy == request.auth.uid;

      // --- Journal Entries ---
      match /entries/{entryId} {
        function isValidEntry(data) {
          return data.keys().hasAll(['transactionId', 'accountId', 'debit', 'credit', 'date']) &&
                 data.transactionId == transactionId &&
                 data.debit is number && data.debit >= 0 &&
                 data.credit is number && data.credit >= 0 &&
                 data.date is string;
        }

        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && isValidEntry(incoming());
        allow delete: if isSignedIn();
      }
    }

    // --- Budgets ---
    function isValidBudget(data) {
      return data.keys().hasAll(['accountId', 'period', 'amount']) &&
             data.amount is number && data.amount >= 0 &&
             data.period is string;
    }

    match /budgets/{budgetId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidBudget(incoming());
      allow delete: if isSignedIn();
    }
  }
}
